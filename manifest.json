{
  "name": "MarkFlow — Markdown Editor",
  "short_name": "MarkFlow",
  "description": "A free, fully-featured Markdown editor that runs in your browser.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#4a90d9",
  "orientation": "any",
  "categories": ["productivity", "utilities"],
  "icons": [
    { "src": "icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/markdown": [".md", ".markdown"],
        "text/plain": [".txt"]
      }
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [{ "name": "file", "accept": ["text/markdown", "text/plain", ".md", ".txt"] }]
    }
  },
  "shortcuts": [
    {
      "name": "New Document",
      "url": "./index.html?action=new",
      "icons": [{ "src": "icon.svg", "sizes": "any" }]
    }
  ]
}
